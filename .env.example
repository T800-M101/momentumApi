# ==============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION (EXAMPLE)
# Copy this file as '.env' and replace the values ​​with your actual credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------------------------
# Format: postgresql://[username]:[password]@[host]:[port]/[database_name]?schema=[schema]
DATABASE_URL="postgresql://postgres:user_password@localhost:5432/journal_db?schema=public"

# ------------------------------------------------------------------------------
# AUTHENTICATION AND SECURITY (JWT)
# ------------------------------------------------------------------------------
# Tip: You can generate secure keys in the terminal using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Secret key to sign Access Tokens (Expires quickly, e.g., 15m)
JWT_ACCESS_SECRET="place_here_a_very_long_random_key"

# Secret key to sign Refresh Tokens (Expires long term, e.g., 7 days)
# It must be a completely different string than the Access Secret string.
JWT_REFRESH_SECRET="coloca_aqui_otra_clave_aleatoria_distinta_y_mas_larga"